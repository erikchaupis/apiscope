{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run APIScope",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "${workspaceFolder}/sample-projects/jwt-api-fastapi"
